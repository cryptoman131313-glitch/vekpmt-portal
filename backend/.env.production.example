# ═══════════════════════════════════════════════════════════════
# ПРОДАКШЕН-КОНФИГУРАЦИЯ ДЛЯ BEGET VPS
# ═══════════════════════════════════════════════════════════════
# Скопировать в .env на сервере и заполнить значения.
# НИКОГДА не коммитить этот файл в Git.
# ═══════════════════════════════════════════════════════════════

# --- Сервер ---
NODE_ENV=production
PORT=3001
# Слушаем только localhost — наружу выставляет nginx
HOST=127.0.0.1

# --- База данных (локальная на VPS) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vekpmt_portal
DB_USER=vekpmt_user
DB_PASSWORD=ЗАМЕНИТЕ_НА_СЛОЖНЫЙ_ПАРОЛЬ
# SSL отключён (локальная БД на том же VPS)
DB_SSL=false

# --- JWT ---
# Сгенерировать командой: openssl rand -hex 32
JWT_SECRET=ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ_МИНИМУМ_32_СИМВОЛА
JWT_EXPIRES_IN=24h

# --- Frontend (CORS) ---
# Через запятую если несколько доменов
FRONTEND_URL=https://portal.vekpmt.ru

# --- SMTP (сброс пароля и уведомления) ---
# Оставь пустым если почта ещё не настроена
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@vekpmt.ru

# --- reCAPTCHA (пока не используется) ---
RECAPTCHA_SECRET=
