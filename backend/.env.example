# Порт сервера
PORT=3001

# База данных (вариант 1: через DATABASE_URL — для облака Railway/Beget Cloud)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# База данных (вариант 2: отдельные поля — для локального PostgreSQL на VPS)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vekpmt_portal
DB_USER=postgres
DB_PASSWORD=CHANGE_ME

# SSL для подключения к БД
# true  — для облачных провайдеров (Railway, Supabase и т.д.)
# false — для локальной БД на VPS (Beget)
DB_SSL=false

# JWT — сгенерируй случайную строку минимум 32 символа
# Например: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_MIN_32_RANDOM_CHARACTERS_HERE
JWT_EXPIRES_IN=24h

# Email (SMTP) — оставь пустым если почта не настроена
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# reCAPTCHA (пока не используется)
RECAPTCHA_SECRET=

# Frontend URL — адрес откуда разрешены запросы (CORS)
FRONTEND_URL=http://localhost:5173
